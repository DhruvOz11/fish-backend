# MongoDB Atlas connection string
# Get this from: Atlas Dashboard → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/freshcatch?retryWrites=true&w=majority

# JWT Secret — make this a long random string (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_please

# Admin credentials (for first login — change after first use)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123

# Port
PORT=5000

# Frontend URL (for CORS — your deployed frontend URL)
FRONTEND_URL=http://localhost:3000

OTP_EXPIRY_MINUTES=10
